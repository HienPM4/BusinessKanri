{
  "name": "GG Sheet Project",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "runServices": ["postgres"],
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "forwardPorts": [3000, 8080, 5432],
  "remoteEnv": {
    "DATABASE_URL": "postgres://postgres:postgres@postgres:5432/sales_db?sslmode=disable",
    "APP_PORT": "8080",
    "NEXT_PUBLIC_API_BASE_URL": "http://localhost:8080/v1"
  },
  "postCreateCommand": "echo 'Codespace ready. Follow docs/github-codespaces-guide.md'",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
